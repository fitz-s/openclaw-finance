  "properties": {
    "run_id": {"type": "string"},
    "instrument": {"type": "string"},
    "safe_bullets": {"type": "array", "items": {"type": "string"}},
    "authority_rule": {"type": "string"},
    "candidate_contract_exclusion": {"const": true},
    "review_only": {"const": true},
    "no_execution": {"const": true}
  },
  "additionalProperties": true
}
